# AI Resume Tailoring Engine — Environment Template
# Copy this file to .env and fill in your values
# .env is gitignored — this file is safe to commit

# Gemini API key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Set to true to enable console logging of agent inputs/outputs during development
DEBUG=false
